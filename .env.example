ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here
WHISPER_MODE=api                      # local or api
WHISPER_DIARIZE=false                 # true にすると話者分離を使用（要 resemblyzer）
WHISPER_MODEL=small                   # base, small, medium, large-v3（ローカルモード時のみ使用）
WHISPER_LANG=ja                       # 言語コード
WHISPER_PROMPT=これは日本語の会議の録音です。参加者が話し合いを行っています。
